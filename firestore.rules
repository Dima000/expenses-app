rules_version = '2';

// Firestore security rules for the single-user expense tracker.
//
// Two things are enforced here (design.md D7 + D2):
//  1. Ownership — every read/write is scoped to the authenticated owner's UID.
//  2. Validation mirror — the SAME checks as @expenses/shared's validateSpending
//     (amount is a positive whole integer, category is a non-empty string,
//     required fields present). Categories are now user-managed data
//     (users/{uid}.categories), so there is no fixed enum to keep in sync.
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function amountOk(data) {
      // Positive whole integer, unless the entry is flagged needsReview (then >= 0).
      return data.amount is int
        && ((data.needsReview == true) ? data.amount >= 0 : data.amount > 0);
    }

    function validSpending(data) {
      return data.keys().hasAll(['amount', 'date', 'comment', 'category', 'ownerUid', 'source'])
        && amountOk(data)
        && data.category is string
        && data.category.size() > 0
        && data.date is string
        && data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && data.comment is string
        && data.source in ['web', 'voice', 'rest']
        && (!('needsReview' in data.keys()) || data.needsReview is bool);
    }

    match /spendings/{spendingId} {
      // Only the owner can read their own records.
      allow read: if isOwner(resource.data.ownerUid);

      // Create: must be owned by the caller and pass the validation mirror.
      allow create: if isOwner(request.resource.data.ownerUid)
        && validSpending(request.resource.data);

      // Update: owner only, ownership cannot change, and the result stays valid.
      allow update: if isOwner(resource.data.ownerUid)
        && request.resource.data.ownerUid == resource.data.ownerUid
        && validSpending(request.resource.data);

      allow delete: if isOwner(resource.data.ownerUid);
    }

    // Per-user data (categories live here). The doc id IS the owner uid,
    // so ownership is the {uid} path param.
    match /users/{uid} {
      allow read, create, update, delete: if isOwner(uid);
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
