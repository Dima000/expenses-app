# Cloud Functions params. Copy to `.env.<projectId>` (e.g. .env.expenses-app-7007d)
# and fill in. These are function config, loaded by the Firebase CLI on deploy.
#
# OWNER_UID: the single owner's Firebase Auth UID. The REST path stamps every
# record with it so REST-written spendings belong to the owner. Find it in the
# Firebase console → Authentication → Users → "User UID". Not a secret, but it is
# a personal identifier, so it is kept out of version control.
OWNER_UID=

# The REST shared secret is NOT set here — it lives in Secret Manager
# (SPENDING_REST_SECRET). Provision it with:
#   firebase functions:secrets:set SPENDING_REST_SECRET
# For local emulator runs, put it in functions/.secret.local (gitignored).
